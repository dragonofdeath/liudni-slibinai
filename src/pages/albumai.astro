---
import Layout from "../layouts/Layout.astro";
import { getAlbums, scaled } from "../lib/cms";

const albums = await getAlbums();
const links = (a: (typeof albums)[number]) => [
  a.spotifyUrl && { href: a.spotifyUrl, label: "Spotify" },
  a.itunesUrl && { href: a.itunesUrl, label: "Apple Music" },
  a.soundcloudUrl && { href: a.soundcloudUrl, label: "SoundCloud" },
  a.deezerUrl && { href: a.deezerUrl, label: "Deezer" },
  a.buyUrl && { href: a.buyUrl, label: "Vinilo plokštelė ↗" },
].filter(Boolean) as { href: string; label: string }[];
---

<Layout title="Albumai">
  <h1 class="page-title">Albumai</h1>
  <div class="albums">
    {albums.map((a) => (
      <article class="album">
        {a.cover && <img src={scaled(a.cover, 520, 520)} width="520" height="520" alt={a.title} loading="lazy" decoding="async" />}
        <div class="album-info">
          <span class="tag">{a.year}</span>
          <h2>{a.title}</h2>
          <p class="muted">{a.description}</p>
          <div class="album-links">
            {links(a).map((l) => (
              <a class="btn" href={l.href} target="_blank" rel="noopener">{l.label}</a>
            ))}
            {a.detailSlug && <a class="more" href={a.detailSlug}>Išsamiau apie albumą…</a>}
          </div>
        </div>
      </article>
    ))}
  </div>
</Layout>

<style>
  .albums { display: flex; flex-direction: column; gap: 2.5rem; }
  .album {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.75rem;
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 1.5rem;
  }
  .album img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 4px; }
  .album-info h2 { font-style: italic; margin: 0.1em 0 0.4em; }
  .album-links { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; margin-top: 0.75rem; }
  .more { font-size: 0.92rem; }
  @media (max-width: 680px) {
    .album { grid-template-columns: 1fr; }
    .album img { max-width: 300px; }
  }
</style>
