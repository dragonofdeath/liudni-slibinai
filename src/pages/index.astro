---
import Layout from "../layouts/Layout.astro";
import { getPosts, getAlbums, formatDate } from "../lib/cms";

const [posts, albums] = await Promise.all([getPosts(4), getAlbums()]);

const HERO_IMG = "https://static.wixstatic.com/media/9d3f58_a7ad7139d77d4e7c8275f45eab870399~mv2.jpg";
const BAND_IMG = "https://static.wixstatic.com/media/9d3f58_af47f689a1a5497792eee5d1fe4414e2~mv2.jpg";
---

<Layout overlayHeader>
  <div class="hero">
    <div class="bg"></div>
    <div class="veil"></div>
    <div class="hero-body">
      <span class="kicker">„grupė“ · nuo 2008 m.</span>
      <h1>liūdni slibinai</h1>
      <p class="sub">
        Liūdnas lietuvio gyvenimo detales apdainuojanti, teatrališkai išradinga ir
        muzikaliai sąmoninga <em>„grupė“</em>, dainuojanti didžių tautos poetų žodžiais.
      </p>
      <div class="rule"></div>
      <div class="actions">
        <a class="btn gold" href="https://open.spotify.com/artist/6zjXlMyonWlkxRMNrlOIrR" target="_blank" rel="noopener">
          Mūsų liūdesio melodijos
        </a>
        <a class="btn" href="https://greenlp.lt" target="_blank" rel="noopener">Vinilo plokštelė</a>
      </div>
    </div>
  </div>

  <div class="wrap">
    <section>
      <div class="sec-head">
        <span class="kicker">Kas naujo liūdesio pasaulyje</span>
        <h2>Naujienos</h2>
        <div class="hair"></div>
      </div>
      <div class="prog">
        {posts.map((p) => (
          <article>
            <time>{formatDate(p.date)}</time>
            <div>
              <h3><a href={`/naujienos/${p.slug}`}>{p.title}</a></h3>
              <p>{p.excerpt?.slice(0, 180)}{(p.excerpt?.length ?? 0) > 180 ? "…" : ""}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="more"><a class="btn" href="/naujienos">Visos naujienos</a></p>
    </section>

    {albums.length > 0 && (
      <section>
        <div class="sec-head">
          <span class="kicker">Diskografija</span>
          <h2>Albumai</h2>
          <div class="hair"></div>
        </div>
        <div class="albums">
          {albums.map((a) => (
            <a class="alb" href="/albumai">
              <div class="img">{a.cover && <img src={a.cover} alt={a.title} loading="lazy" />}</div>
              <h3>{a.title}</h3>
              <div class="yr">{a.year}</div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <div class="band">
    <img src={BAND_IMG} alt="liūdni slibinai" loading="lazy" />
    <div class="in">
      <blockquote>„Gyvenimas liūdnas, bet tai — nieko blogo.“</blockquote>
      <cite>liūdni slibinai</cite>
    </div>
  </div>
</Layout>

<style define:vars={{ heroImg: `url(${HERO_IMG})` }}>
  .hero { position: relative; min-height: 92vh; display: flex; flex-direction: column; }
  .bg {
    position: absolute; inset: 0;
    background: var(--heroImg) center 30% / cover no-repeat;
    filter: saturate(0.85) brightness(0.72) contrast(1.04);
  }
  .veil {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(18,21,28,.55) 0%, rgba(18,21,28,.15) 45%, var(--bg) 96%);
  }
  .hero-body {
    position: relative; flex: 1;
    display: flex; flex-direction: column; justify-content: flex-end; align-items: center;
    text-align: center; padding: 16vh 20px 9vh;
  }
  .hero h1 {
    font-weight: 500; font-style: italic;
    font-size: clamp(56px, 9vw, 110px);
    line-height: 1; letter-spacing: 0.01em; margin: 0.1em 0 0;
    text-shadow: 0 4px 40px rgba(0,0,0,.5);
  }
  .sub { margin-top: 20px; max-width: 34em; color: #d8d2c4; font-size: 18px; }
  .sub em { color: var(--gold); }
  .rule { width: 72px; border-top: 1px solid var(--gold); margin: 30px auto 26px; }
  .actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  section { padding: 90px 0 0; }
  .prog { max-width: 760px; margin: 0 auto; }
  .prog article { padding: 34px 8px; border-top: 1px solid var(--line); display: flex; gap: 34px; align-items: baseline; }
  .prog article:last-child { border-bottom: 1px solid var(--line); }
  .prog time {
    font-size: 12px; letter-spacing: 0.22em; color: var(--dim);
    text-transform: uppercase; white-space: nowrap; width: 96px;
  }
  .prog h3 { font-weight: 600; font-size: 27px; line-height: 1.2; margin: 0; }
  .prog p { color: var(--dim); margin: 8px 0 0; font-size: 16px; }
  .more { text-align: center; margin-top: 2.4rem; }

  .albums { display: grid; grid-template-columns: repeat(4, 1fr); gap: 26px; padding-bottom: 20px; }
  .alb { text-align: center; }
  .alb .img { position: relative; overflow: hidden; }
  .alb img {
    width: 100%; aspect-ratio: 1; object-fit: cover; display: block;
    transition: transform 0.45s ease; filter: brightness(0.92);
  }
  .alb:hover img { transform: scale(1.045); }
  .alb h3 { font-style: italic; font-weight: 600; font-size: 20px; margin: 16px 0 0; }
  .alb .yr { font-size: 12px; letter-spacing: 0.26em; color: var(--dim); margin-top: 4px; }

  .band { margin-top: 100px; position: relative; height: clamp(340px, 32vw, 560px); overflow: hidden; }
  .band img {
    width: 100%; height: 100%; object-fit: cover; object-position: center 62%;
    filter: saturate(0.7) brightness(0.5);
  }
  .band .in {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center; padding: 0 24px;
  }
  .band blockquote {
    font-family: var(--font-display); font-style: italic; font-weight: 500;
    font-size: clamp(24px, 3.4vw, 36px); max-width: 24em; line-height: 1.3; margin: 0;
  }
  .band cite {
    margin-top: 16px; font-style: normal; font-size: 12px;
    letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold);
  }

  @media (max-width: 860px) {
    .albums { grid-template-columns: repeat(2, 1fr); }
    .prog article { flex-direction: column; gap: 8px; }
    .hero { min-height: 70vh; }
  }
</style>
