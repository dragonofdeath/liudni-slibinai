---
import Layout from "../../layouts/Layout.astro";
import { getGalleryBySlug, galleryImages, scaled } from "../../lib/cms";

const { slug } = Astro.params;
const gallery = await getGalleryBySlug(slug!);
if (!gallery) return Astro.redirect("/foto");
const imgs = galleryImages(gallery);
---

<Layout title={gallery.title}>
  <h1 class="page-title">{gallery.title}</h1>
  <div class="masonry">
    {imgs.map((img, i) => (
      <a href={img.url} target="_blank" rel="noopener">
        <img src={scaled(img.url, 900)} width={img.w} height={img.h} alt={`${gallery.title} — ${i + 1}`} loading="lazy" decoding="async" />
      </a>
    ))}
  </div>
  <p><a href="/foto">← Visos galerijos</a></p>
</Layout>

<style>
  .masonry { columns: 3 280px; column-gap: 1rem; margin-bottom: 2rem; }
  .masonry a { display: block; margin-bottom: 1rem; break-inside: avoid; }
  .masonry img {
    width: 100%; height: auto; display: block; border-radius: 4px;
    border: 1px solid var(--line); transition: border-color 0.2s ease;
  }
  .masonry a:hover img { border-color: var(--gold); }
</style>
