---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** transparent header laid over a full-bleed hero (home page) */
  overlayHeader?: boolean;
}

const { title, description, overlayHeader = false } = Astro.props;
const fullTitle = title ? `${title} | liūdni slibinai` : `liūdni slibinai | „grupė“`;
const desc = description ??
  "Liūdnas lietuvio gyvenimo detales apdainuojanti, teatrališkai išradinga ir muzikaliai sąmoninga „grupė“, gyvuojanti nuo 2008 m.";

const nav = [
  { href: "/naujienos", label: "Naujienos" },
  { href: "/albumai", label: "Albumai" },
  { href: "/video", label: "Video" },
  { href: "/foto", label: "Foto" },
  { href: "/tekstai", label: "Tekstai" },
  { href: "/apie", label: "Apie" },
  { href: "/kontaktai", label: "Kontaktai" },
  { href: "/en", label: "EN" },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="lt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class:list={[overlayHeader && "overlay"]}>
      <div class="topbar">
        <a class="wordmark" href="/">liūdni slibinai</a>
        <input type="checkbox" id="nav-toggle" aria-hidden="true" />
        <label for="nav-toggle" class="nav-burger" aria-label="Meniu">☰</label>
        <nav>
          {nav.map((item) => (
            <a href={item.href} class:list={[path.startsWith(item.href) && "active"]}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      {overlayHeader ? <slot /> : <div class="wrap page-pad"><slot /></div>}
    </main>

    <footer>
      <div class="footer-inner">
        <div class="soc">
          <a href="https://open.spotify.com/artist/6zjXlMyonWlkxRMNrlOIrR" target="_blank" rel="noopener">Spotify</a>
          <a href="https://www.youtube.com/@liudnislibinai" target="_blank" rel="noopener">YouTube</a>
          <a href="https://www.instagram.com/liudnislibinai/" target="_blank" rel="noopener">Instagram</a>
        </div>
        <p class="muted small">
          <a href="mailto:info@liudnislibinai.lt">info@liudnislibinai.lt</a> · © {new Date().getFullYear()} liūdni slibinai — liūdesys nuo 2008 m.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  header {
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }
  header.overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 5;
    background: transparent;
    border-bottom: 0;
  }
  .topbar {
    max-width: 1180px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 34px;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .wordmark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 22px;
    color: var(--fg);
    white-space: nowrap;
  }
  nav { display: flex; gap: 24px; flex-wrap: wrap; }
  nav a {
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #cfc9bc;
  }
  nav a:hover, nav a.active { color: var(--gold); }

  #nav-toggle, .nav-burger { display: none; }

  @media (max-width: 860px) {
    .nav-burger {
      display: block;
      color: var(--fg);
      font-size: 1.35rem;
      cursor: pointer;
      user-select: none;
    }
    nav {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 0.8rem;
      padding: 0.75rem 0 0.5rem;
    }
    #nav-toggle:checked ~ nav { display: flex; }
    header.overlay { position: static; background: var(--bg); border-bottom: 1px solid var(--line); }
  }

  footer { border-top: 1px solid var(--line); }
  .footer-inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 3.2rem 1.5rem 3.6rem;
    text-align: center;
  }
  .soc {
    display: flex;
    gap: 30px;
    justify-content: center;
    margin-bottom: 16px;
    font-size: 11.5px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .soc a { color: var(--dim); }
  .soc a:hover { color: var(--gold); }
  .footer-inner p a { color: var(--dim); }
  .footer-inner p a:hover { color: var(--gold); }
</style>
